{
  "title": "Job Application Platform",
  "uid": "job-app-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate — Auth Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_count{job=\"auth-service\"}[1m])",
          "legendFormat": "{{method}} {{route}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Request Rate — JobApp Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_count{job=\"jobapp-service\"}[1m])",
          "legendFormat": "{{method}} {{route}} {{status_code}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate — Auth Service (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_count{job=\"auth-service\",status_code=~\"5..\"}[1m])",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Rate — JobApp Service (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_count{job=\"jobapp-service\",status_code=~\"5..\"}[1m])",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "P95 Latency — Auth Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"auth-service\"}[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 6,
      "title": "P95 Latency — JobApp Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"jobapp-service\"}[5m]))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
